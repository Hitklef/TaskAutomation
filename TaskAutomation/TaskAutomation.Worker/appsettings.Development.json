{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AzureDevOps": {
    "PersonalAccessToken": "set-in-user-secrets-or-env"
  },
  "Persistence": {
    "ConnectionString": "Data Source=task-automation.dev.db"
  },
  "Workflow": {
    "AutoTransitionEnabled": true,
    "EnableTodoPolling": true,
    "TodoPollingIntervalMinutes": 1
  },
  "RepositoryContext": {
    "LocalRepositoryPath": ""
  }
}
